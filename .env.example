# masha-bot environment variables
# Copy this file to .env and fill in your actual values

# ── Telegram ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100YOUR_CHANNEL_ID
CHANNEL_USERNAME=@bmw_mpower_club
OWNER_ID=YOUR_OWNER_ID

# ── Pollinations AI ───────────────────────────────────────────────────────
POLLINATIONS_API_KEY=your_pollinations_api_key_here
POLLINATIONS_API_KEY_2=your_pollinations_api_key_2_here

# ── GitHub ────────────────────────────────────────────────────────────────
GH_PAT_TOKEN=your_github_pat_token_here
GH_REPO=sochiautoparts/masha-bot

# ── Database ──────────────────────────────────────────────────────────────
DB_PATH=masha_bot.db

# ── Scheduling ────────────────────────────────────────────────────────────
POST_INTERVAL_MINUTES=30
MAX_POSTS_PER_DAY=20
MIN_POSTS_PER_DAY=6

# ── Content ───────────────────────────────────────────────────────────────
ENABLE_IMAGES=true
ENABLE_FACT_CHECK=true

# ── Bot Mode ──────────────────────────────────────────────────────────────
# Options: single (one cycle), interactive (long polling)
MASHA_BOT_MODE=single

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
